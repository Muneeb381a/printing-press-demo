PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
# Option A: Neon / any cloud Postgres (recommended for production)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Dev:  http://localhost:5173
# Prod: https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:5173

# ── Authentication ────────────────────────────────────────────
# Generate secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-hex-string

ADMIN_USERNAME=printing
ADMIN_PASSWORD=printing123
